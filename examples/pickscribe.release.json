{
  "schemaVersion": 1,
  "repository": "pickforge/pickscribe",
  "appName": "PickScribe",
  "tauriConfig": "src-tauri/tauri.conf.json",
  "collect": {
    "artifactRoot": "target/release/bundle",
    "outputDir": "release-assets",
    "patterns": [
      "*.AppImage",
      "*.AppImage.sig",
      "*.deb",
      "*.deb.sig"
    ]
  },
  "stable": {
    "tagPrefix": "v",
    "latestJsonAsset": "latest.json"
  },
  "nightly": {
    "enabled": true,
    "branch": "main",
    "tagPrefix": "nightly-",
    "latestJsonAsset": "nightly.json"
  },
  "updater": {
    "requiredPlatforms": [
      "linux-x86_64"
    ]
  }
}

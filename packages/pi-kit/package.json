{
  "name": "@pickforge/pi-kit",
  "version": "0.1.0",
  "description": "Personal Pi sovereignty kit: lane runner + TUI, model policy, event journal, delivery gates, vault promotion.",
  "type": "module",
  "private": true,
  "bin": {
    "pickforge-lanes-mcp": "./mcp/server.ts"
  },
  "pi": {
    "extensions": [
      "extensions/table.ts",
      "extensions/journal.ts",
      "extensions/lanes.ts",
      "extensions/gates.ts",
      "extensions/delegation.ts",
      "extensions/grill-review.ts",
      "extensions/vault.ts",
      "extensions/compact-tools.ts",
      "extensions/ember-footer.ts"
    ],
    "themes": [
      "themes"
    ]
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "mcp": "bun mcp/server.ts"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "0.79.10",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0",
    "typebox": "1.1.38",
    "@earendil-works/pi-ai": "0.79.10",
    "@earendil-works/pi-tui": "0.79.10"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "^4.4.3"
  }
}